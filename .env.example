# Copy to .env (kept out of git) to configure the local-agent.
# Real environment variables always override these.

# Password login. If unset, the agent runs OPEN (clients connect directly, no
# login step) — only safe on loopback. Set a password to require login; REQUIRED
# whenever the agent is reachable beyond loopback.
# MAC_AGENT_PASSWORD=change-me

# Bind address. Default 127.0.0.1 (loopback only) — keep this when fronted by
# `tailscale serve` (it proxies to localhost). Set to your Tailscale IP for
# direct access without serve, or 0.0.0.0 for all interfaces (only with a password!).
# MAC_AGENT_BIND=100.x.y.z

# Headless permission mode for driven sessions: default | auto | acceptEdits |
# bypassPermissions | plan
# CLAUDE_PERMISSION_MODE=acceptEdits

# Ports used by `make start` / scripts/dev-control.sh. Defaults below.
# WEB_PORT=3005
# AGENT_PORT=7345

# Agent's HTTPS port behind `tailscale serve` (must match the `--https=` you pass
# for the agent). Baked into the web build so the client auto-fills it on *.ts.net.
# AGENT_HTTPS_PORT=8443

# How many messages to render when first opening a session (load-earlier pages
# stay 40). Baked into the web build. Default 10.
# INITIAL_MESSAGES=10

# --- 监控台"当前任务"摘要（current task summary）---
# 用第三方 OpenAI 兼容 API 总结每个会话当前在做什么（仅 API；不配置则该功能关闭，
# 不再有本机 Haiku 旁路）。CURRENT_TASK_SUMMARY=0 可整体关闭。
# CURRENT_TASK_SUMMARY=on
# 内置模型别名（自动带出 base_url + thinking 约定）：
#   ds-v4-flash | ds-v4-pro | glm5.1 | qwen3.6-27b | kimi-k2.6 | minimax-m2.7
# 用内置别名时只需填 KEY + MODEL；接其它 OpenAI 兼容服务则再填 BASE_URL。
# LLM_API_KEY=your-api-key
# LLM_API_MODEL=ds-v4-flash
# LLM_API_BASE_URL=https://your-openai-compatible-host
# LLM_API_TIMEOUT_MS=20000

# --- Voice input / ASR (Tencent Cloud 一句话识别) ---
# Needed for voice input. Get the key pair from the Tencent Cloud console:
# https://console.cloud.tencent.com/cam/capi (ASR service must be enabled).
# Voice input also needs HTTPS in the browser (see docs/remote-access.md).
# VOICE_SECRET_ID=your-secret-id
# VOICE_SECRET_KEY=your-secret-key
# Region. Default ap-guangzhou. e.g. ap-shanghai / ap-beijing.
# VOICE_REGION=ap-guangzhou
