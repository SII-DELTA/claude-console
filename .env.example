# Copy to .env (kept out of git) to configure the local-agent.
# Real environment variables always override these.

# Enable password login. Any non-empty value turns on auth (overrides MAC_AGENT_NO_AUTH).
MAC_AGENT_PASSWORD=change-me

# Bind address. Default 127.0.0.1 (loopback only). Set to a Tailscale IP to expose
# only on your tailnet, or 0.0.0.0 to bind all interfaces (use with auth!).
# MAC_AGENT_BIND=100.x.y.z

# Headless permission mode for driven sessions: default | auto | acceptEdits |
# bypassPermissions | plan
# CLAUDE_PERMISSION_MODE=acceptEdits

# Skip auth entirely (local convenience only). Ignored if MAC_AGENT_PASSWORD is set.
# MAC_AGENT_NO_AUTH=1
