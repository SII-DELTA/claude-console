{
  "name": "claude-console",
  "version": "0.1.0",
  "private": true,
  "description": "Claude Console — a proxy-free, customizable remote client for Claude Code; drive your computer's AI coding sessions from any browser.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" --filter \"./apps/web\" build",
    "dev": "pnpm -r --parallel --filter \"./packages/local-agent\" --filter \"./apps/web\" dev",
    "lint": "pnpm -r --filter \"./packages/*\" --filter \"./apps/web\" lint",
    "typecheck": "pnpm -r --filter \"./packages/*\" --filter \"./apps/web\" typecheck",
    "test": "pnpm -r --filter \"./packages/*\" --filter \"./apps/web\" test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\" --ignore-path .gitignore",
    "clean": "pnpm -r exec rm -rf dist .next .turbo node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
